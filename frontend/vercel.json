{
  "rewrites": [
    {
      "source": "/api/productos/:id/imagen",
      "destination": "/api/proxy-upload?path=productos/:id/imagen&isUpload=1"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/proxy?path=:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "/api/proxy?path=uploads/:path*&isUpload=1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
